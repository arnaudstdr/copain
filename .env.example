# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
ALLOWED_USER_ID=123456789

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:31b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
# Timeout (en secondes) des appels LLM. gemma4:31b-cloud sur une recherche
# web chaîne 2 appels, 120 s est un défaut confortable.
OLLAMA_TIMEOUT_SEC=120

# SearXNG
SEARXNG_BASE_URL=http://localhost:8888

# Chemins données
DATA_DIR=./data
CHROMA_DIR=./data/chroma
DB_PATH=./data/tasks.db
SCHEDULER_DB_PATH=./data/scheduler.db

# Fuseau horaire (utilisé par dateparser ET APScheduler)
TZ=Europe/Paris

# Briefing matinal planifié (cron local)
BRIEFING_HOUR=8
BRIEFING_MINUTE=0

# Coordonnées pour la météo (Open-Meteo, pas de clé API)
HOME_LAT=48.26
HOME_LON=7.45
HOME_CITY=Sélestat

# iCloud Calendar (CalDAV)
# App-Specific Password obligatoire (Apple ID 2FA).
# Créer sur : https://appleid.apple.com → Connexion et sécurité → Mots de passe pour apps
ICLOUD_USERNAME=your.email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ICLOUD_CALENDAR_NAME=Personnel

# Proactivité (notifications poussées sans demande : pluie imminente,
# rappel de RDV ~1h avant). Opt-in explicite. Garde-fous : fenêtre horaire,
# cooldown par type, budget quotidien. La table `notification_logs` est créée
# dans `tasks.db` au premier démarrage.
PROACTIVITY_ENABLED=false
PROACTIVITY_WINDOW_START_HOUR=8
PROACTIVITY_WINDOW_END_HOUR=21
PROACTIVITY_DAILY_BUDGET=3
PROACTIVITY_CHECK_INTERVAL_MIN=30
PROACTIVITY_RAIN_COOLDOWN_HOURS=3

# Logs — fichier rotatif JSON, persisté dans le volume Docker.
# Rotation : 5 Mo × 5 backups (~30 Mo max). Créé automatiquement.
# Mettre vide pour désactiver la persistance fichier (seul stdout reste actif).
LOG_FILE_PATH=./data/logs/bot.log

# Environnement (dev | prod) — conditionne le format de log structlog
ENV=dev
