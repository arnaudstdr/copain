# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
ALLOWED_USER_ID=123456789

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:31b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text

# SearXNG
SEARXNG_BASE_URL=http://localhost:8888

# Chemins données
DATA_DIR=./data
CHROMA_DIR=./data/chroma
DB_PATH=./data/tasks.db
SCHEDULER_DB_PATH=./data/scheduler.db

# Fuseau horaire (utilisé par dateparser ET APScheduler)
TZ=Europe/Paris

# Briefing matinal planifié (cron local)
BRIEFING_HOUR=8
BRIEFING_MINUTE=0

# Coordonnées pour la météo (Open-Meteo, pas de clé API)
HOME_LAT=48.26
HOME_LON=7.45
HOME_CITY=Sélestat

# iCloud Calendar (CalDAV)
# App-Specific Password obligatoire (Apple ID 2FA).
# Créer sur : https://appleid.apple.com → Connexion et sécurité → Mots de passe pour apps
ICLOUD_USERNAME=your.email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ICLOUD_CALENDAR_NAME=Personnel

# Environnement (dev | prod) — conditionne le format de log structlog
ENV=dev
