# Telegram
TELEGRAM_BOT_TOKEN=your_token_here
ALLOWED_USER_ID=123456789

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:31b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
# Timeout (en secondes) des appels LLM. gemma4:31b-cloud sur une recherche
# web chaîne 2 appels, 120 s est un défaut confortable.
OLLAMA_TIMEOUT_SEC=120
# Taille de contexte passée explicitement à Ollama via `options.num_ctx`.
# Sans ce paramètre, Ollama applique un default serveur qui peut être très bas
# (bug/régression cloud observé en 04/2026 : crash avec `prompt too long`
# même sur des prompts courts). On force ici une valeur généreuse mais sous
# les 256k max de gemma4:31b-cloud.
OLLAMA_NUM_CTX=32768

# Fallback LLM local (optionnel). Si OLLAMA_FALLBACK_MODEL est défini, le
# client Ollama bascule automatiquement sur ce modèle quand le primary
# timeout ou renvoie une erreur. Jamais déclenché pour les messages photo
# (modèle local non multimodal). Les réponses fallback ne sont PAS mises en
# cache pour qu'on retente le primary au prochain message.
# Pour activer : `ollama pull gemma3:4b` sur le Pi puis décommenter.
OLLAMA_FALLBACK_MODEL=
# Par défaut le fallback utilise la même base URL que le primary.
OLLAMA_FALLBACK_BASE_URL=
OLLAMA_FALLBACK_TIMEOUT_SEC=60
OLLAMA_FALLBACK_NUM_CTX=8192

# SearXNG
SEARXNG_BASE_URL=http://localhost:8888

# Cache de réponses. LLM opt-in (activé uniquement sur les appels sans bloc
# <meta> ni side effects : résumés SearXNG, résumés RSS du briefing).
# SearXNG en cache sur chaque recherche. Les réponses issues du fallback LLM
# ne sont jamais cachées.
CACHE_LLM_TTL_SEC=21600
CACHE_LLM_MAX_SIZE=128
CACHE_SEARXNG_TTL_SEC=3600
CACHE_SEARXNG_MAX_SIZE=128

# Chemins données
DATA_DIR=./data
CHROMA_DIR=./data/chroma
DB_PATH=./data/tasks.db
SCHEDULER_DB_PATH=./data/scheduler.db

# Fuseau horaire (utilisé par dateparser ET APScheduler)
TZ=Europe/Paris

# Briefing matinal planifié (cron local)
BRIEFING_HOUR=8
BRIEFING_MINUTE=0

# Coordonnées pour la météo (Open-Meteo, pas de clé API)
HOME_LAT=48.26
HOME_LON=7.45
HOME_CITY=Sélestat

# iCloud Calendar (CalDAV)
# App-Specific Password obligatoire (Apple ID 2FA).
# Créer sur : https://appleid.apple.com → Connexion et sécurité → Mots de passe pour apps
ICLOUD_USERNAME=your.email@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ICLOUD_CALENDAR_NAME=Personnel

# Proactivité (notifications poussées sans demande : pluie imminente,
# rappel de RDV ~1h avant). Opt-in explicite. Garde-fous : fenêtre horaire,
# cooldown par type, budget quotidien. La table `notification_logs` est créée
# dans `tasks.db` au premier démarrage.
PROACTIVITY_ENABLED=false
PROACTIVITY_WINDOW_START_HOUR=8
PROACTIVITY_WINDOW_END_HOUR=21
PROACTIVITY_DAILY_BUDGET=3
PROACTIVITY_CHECK_INTERVAL_MIN=30
PROACTIVITY_RAIN_COOLDOWN_HOURS=3

# Prix carburants (data.economie.gouv.fr, sans clé API)
# Rayon de recherche par défaut quand l'utilisateur ne le précise pas.
FUEL_DEFAULT_RADIUS_KM=10
# User-Agent obligatoire pour Nominatim (géocoding OSM). Policy OSM :
# https://operations.osmfoundation.org/policies/nominatim/
NOMINATIM_USER_AGENT=copain-bot/1.0 (personal assistant)

# Logs — fichier rotatif JSON, persisté dans le volume Docker.
# Rotation : 5 Mo × 5 backups (~30 Mo max). Créé automatiquement.
# Mettre vide pour désactiver la persistance fichier (seul stdout reste actif).
LOG_FILE_PATH=./data/logs/bot.log

# Environnement (dev | prod) — conditionne le format de log structlog
ENV=dev
